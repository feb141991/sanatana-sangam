# ─────────────────────────────────────────────────────────────────
# Sanatana Sangam — Environment Variables
# Copy this file to .env.local and fill in your Supabase credentials
# Get these from: https://supabase.com → Your Project → Settings → API
# ─────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Optional: only needed for admin operations
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Public support email shown on the contact page
NEXT_PUBLIC_SUPPORT_EMAIL=

# ─── OneSignal (free push notifications) ──────────────────────────
# Get from: https://onesignal.com → Your App → Settings → Keys & IDs
NEXT_PUBLIC_ONESIGNAL_APP_ID=YOUR_ONESIGNAL_APP_ID
ONESIGNAL_REST_API_KEY=YOUR_ONESIGNAL_REST_API_KEY
CRON_SECRET=YOUR_CRON_SECRET

# ─── Google Gemini (AI chat & Dharma AI) ──────────────────────────
# Get from: https://aistudio.google.com → Get API Key (free tier available)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash

# ─── Standalone Admin Auth ─────────────────────────────────────────
# Completely independent from Supabase. Only used by the /admin portal.
# Generate ADMIN_SECRET with: openssl rand -hex 32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD
ADMIN_SECRET=YOUR_32_CHAR_HEX_SECRET
