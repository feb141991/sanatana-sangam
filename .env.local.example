# ─────────────────────────────────────────────────────────────────
# Sanatana Sangam — Environment Variables
# Copy this file to .env.local and fill in your Supabase credentials
# Get these from: https://supabase.com → Your Project → Settings → API
# ─────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Optional: only needed for admin operations
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ─── OneSignal (free push notifications) ──────────────────────────
# Get from: https://onesignal.com → Your App → Settings → Keys & IDs
NEXT_PUBLIC_ONESIGNAL_APP_ID=YOUR_ONESIGNAL_APP_ID

# ─── Google Gemini (AI chat & Dharma AI) ──────────────────────────
# Get from: https://aistudio.google.com → Get API Key (free tier available)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
