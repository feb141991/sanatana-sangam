<?xml version="1.0" encoding="utf-8"?>
<!--
  ─── Android Network Security Config ──────────────────────────────────────────
  Place at: android/app/src/main/res/xml/network_security_config.xml

  Allows HTTPS to all domains, specifically trusts Supabase and Vercel certs.
  Blocks all cleartext (HTTP) traffic in production.
  ─────────────────────────────────────────────────────────────────────────────
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext only on localhost for development live-reload -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Add your dev machine's local IP here for livereload:
             <domain includeSubdomains="false">192.168.x.x</domain>
        -->
    </domain-config>
</network-security-config>
