{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "incremental": false,
    "noEmit": false,
    "allowJs": false,
    "jsx": "react-jsx",
    "lib": ["es2020", "dom"],
    "module": "esnext",
    "target": "es2020",
    "moduleResolution": "bundler",
    "types": []
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
